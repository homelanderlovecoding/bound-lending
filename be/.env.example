# App
APP_PORT=3000
APP_ENV=development
API_SECRET_KEY=your-secret-key
API_SECRET_WORD=your-secret-word
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URI=mongodb://localhost:27017/bound-lending

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Bitcoin
BITCOIN_NETWORK=regtest
BOUND_PUBKEY=
BOUND_PRIVATE_KEY=

# Price Feeds
PRICE_FEED_INTERVAL_MS=60000
ORACLE_DIFFERENTIAL_THRESHOLD_PCT=0.25
ORACLE_RETRY_WAIT_MS=300000

# Lending Config
ORIGINATION_FEE_PCT=0.2
GRACE_PERIOD_DAYS=7
LIQUIDATION_LTV_PCT=95
MIN_LOAN_AMOUNT_USD=100
MIN_LOAN_TERM_DAYS=30
MAX_LTV_PCT=80
ON_CHAIN_CONFIRMATION_THRESHOLD=3
MANUAL_REVIEW_BTC_THRESHOLD=0.20

# RadFi (Bound Trading Wallet — signet)
RADFI_BASE_URL=https://signet.ums.radfi.co

# UniSat (on-chain Runes indexer — signet)
UNISAT_BASE_URL=https://open-api-signet.unisat.io
UNISAT_API_KEY=

# bUSD Rune ID (shared between RadFi + UniSat)
BUSD_RUNE_ID=
